# Staging 环境变量模板（复制为 .env 或 OPERONE_STAGING=1 一键部署时自动写入）
# cp .env.staging.example .env

STAGING=1
OPERONE_STAGING=1

# OpenGame Browser Bench：复杂 Agentic 生成后真浏览器探测 + 可选 repair
OPENGAME_BROWSER_BENCH=1
OPENGAME_BROWSER_BENCH_REPAIR=1
# OPENGAME_BROWSER_BENCH_REQUIRED=1

# Agentic 试玩探测页（/qa/agentic-bench）
QA_ROUTES_ENABLED=1

# Comfy 精灵：256 预览 → 512/1024 精修（需 COMFY_UI_BASE_URL）
GAME_SPRITE_COMFY=1
# GAME_SPRITE_OUTPUT_PX=1024
# COMFY_UI_BASE_URL=http://127.0.0.1:8188

# OpenGame Pro CLI（本机安装 opengame 后开启）
# OPENGAME_CLI=1
# OPENGAME_CLI_BRIDGE=1

PLAYWRIGHT_BASE_URL=http://127.0.0.1:80
ORCHESTRATION_QUALITY_TIER=astrocade
