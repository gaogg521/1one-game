{
  "name": "game",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/run-dev.mjs",
    "build": "next build",
    "build:full": "prisma generate && next build",
    "start": "node scripts/run-start.mjs",
    "restart": "npm run dev",
    "restart:dev": "npm run dev",
    "restart:prod": "node scripts/restart-prod.mjs",
    "lint": "eslint",
    "qa:orch-smoke": "tsx scripts/qa-orchestration-smoke.ts",
    "qa:creative-brief": "tsx scripts/qa-creative-brief-smoke.ts",
    "qa:novel-comic-smoke": "tsx scripts/qa-novel-comic-smoke.ts",
    "qa:director-spec": "tsx scripts/qa-director-spec.ts",
    "qa:refinement-log": "tsx scripts/qa-refinement-log.ts",
    "qa:template-matrix": "tsx scripts/qa-template-matrix.ts",
    "qa:studio-duplicate": "tsx scripts/qa-studio-duplicate.ts",
    "qa:godot-bridge": "tsx scripts/qa-godot-spec-bridge.ts",
    "godot:install": "powershell -ExecutionPolicy Bypass -File scripts/godot-install.ps1",
    "godot:install:linux": "bash scripts/godot-install-linux.sh",
    "godot:install:templates:linux": "bash scripts/godot-install-templates-linux.sh",
    "godot:install:ci": "bash scripts/godot-install-ci.sh",
    "godot:import": "powershell -ExecutionPolicy Bypass -File scripts/godot.ps1 --headless --path godot-templates/ai-mother-universal --import",
    "godot:run": "powershell -ExecutionPolicy Bypass -File scripts/godot.ps1 --path godot-templates/ai-mother-universal",
    "godot:export:mother": "powershell -ExecutionPolicy Bypass -File scripts/godot-export-mother.ps1",
    "godot:export:desktop": "powershell -ExecutionPolicy Bypass -File scripts/godot-export-desktop.ps1",
    "godot:export:project": "tsx scripts/qa-godot-export-project.ts",
    "qa:godot-export": "tsx scripts/qa-godot-export.ts",
    "qa:godot-export:matrix": "tsx scripts/qa-godot-export-matrix.ts",
    "qa:enrich-spec": "tsx scripts/qa-enrich-spec.ts",
    "qa:full": "powershell -ExecutionPolicy Bypass -File scripts/run-full-qa.ps1",
    "qa:comic-32-panels": "node scripts/run-comic-32-panel-longtest.mjs",
    "simulate:handtest": "node scripts/simulate-handtest.mjs",
    "test:e2e": "playwright test",
    "test:e2e:godot": "playwright test e2e/godot-runtime.smoke.spec.ts e2e/godot-templates-matrix.spec.ts",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "@fontsource/noto-sans-sc": "^5.2.5",
    "@fontsource/noto-serif-sc": "^5.2.9",
    "@prisma/client": "^5.22.0",
    "@tavily/core": "^0.7.3",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "nanoid": "^5.1.11",
    "next": "16.2.6",
    "openai": "^6.37.0",
    "pdf-parse": "^2.4.5",
    "phaser": "^4.1.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.34.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@colbymchenry/codegraph": "^0.7.9",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prisma": "^5.22.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
