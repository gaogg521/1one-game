; Engine configuration file.
; AI 母版：2D 平台跳跃，字段对齐 GameSpec（见 docs/godot-quickstart-cn.md）

config_version=5

[application]

config/name="AI Mother Universal"
config/description="Operone GameSpec 全品类专业运行时"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameSpecData="*res://scripts/autoload/game_spec_data.gd"
GameAudio="*res://scripts/autoload/game_audio.gd"
GameUiFont="*res://scripts/autoload/game_ui_font.gd"

[display]

window/size/viewport_width=800
window/size/viewport_height=600
window/stretch/mode="canvas_items"

[input]

