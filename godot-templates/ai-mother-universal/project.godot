[physics]

2d/default_gravity=980.0

[debug]

gdscript/warnings/untyped_declaration=0
gdscript/warnings/inferred_declaration=0
gdscript/warnings/unsafe_call_argument=0
gdscript/warnings/unsafe_method_access=0
gdscript/warnings/unsafe_property_access=0
gdscript/warnings/unsafe_cast=0
gdscript/warnings/return_value_discarded=0
gdscript/warnings/property_used_as_function=0
gdscript/warnings/function_used_as_property=0
gdscript/warnings/integer_division=0
gdscript/warnings/narrowing_conversion=0
gdscript/warnings/int_as_enum_without_cast=0
gdscript/warnings/int_division=0
gdscript/warnings/empty_file=0
gdscript/warnings/deprecated_keyword=0
gdscript/warnings/standalone_expression=0
gdscript/warnings/standalone_ternary=0
gdscript/warnings/shadowed_variable=0
gdscript/warnings/onready_with_export=0
gdscript/warnings/export_private=0

[rendering]

renderer/rendering_method="gl_compatibility"
