DATABASE_URL="file:./dev.db"

# ---------- OpenAI SDK 兼容网关（可把 OpenClaw 里 litellm 的 apiKey / baseUrl 填在这里） ----------
OPENAI_API_KEY=
# LiteLLM 根地址；若末尾无 /v1 会自动补上（示例与 OpenClaw models.providers.litellm.baseUrl 一致）
OPENAI_BASE_URL=https://litellm-internal.123u.com
# 主模型：对应 OpenClaw litellm/gpt-5.2 → 此处写 gpt-5.2
OPENAI_MODEL=gpt-5.2
# 备用模型（逗号分隔），顺序对应 OpenClaw fallbacks（可写 litellm/xxx 或直接写网关 model id）
OPENAI_MODEL_FALLBACKS=kimi-k2-6,gemini-3.1-pro-preview,Doubao-Seed-2-Code,gpt-5-4-mini,qwen-3-6-plus,glm-5-1

# OpenClaw 里 litellm.headers 可整块挪成 JSON（值须为字符串或数字）
# OPENAI_EXTRA_HEADERS_JSON={"x-openclaw-timeout-ms":"25000"}

# 部分网关校验 UA，不需要可留空
OPENAI_USER_AGENT=

# ---------- 参考图 / 素材存储（默认仅会话：服务端不保留像素；解析返回的 refId 由前端写入 sessionStorage） ----------
# session | cloud
REFERENCE_ASSET_STORAGE=session
# 云模式：上传端点（实现见 src/lib/assets/reference-image-storage.cloud.ts）
# REFERENCE_ASSET_CLOUD_UPLOAD_URL=
# 可选鉴权头（Bearer 等，具体以上传服务约定为准）
# REFERENCE_ASSET_CLOUD_AUTH_HEADER=

# Docker：可与 compose 中 volume 对齐，例如 file:/app/data/app.sqlite
