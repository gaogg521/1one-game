DATABASE_URL="file:./dev.db"

# ---------- OpenAI SDK 兼容网关（可把 OpenClaw 里 litellm 的 apiKey / baseUrl 填在这里） ----------
OPENAI_API_KEY=
# LiteLLM 根地址；若末尾无 /v1 会自动补上（示例与 OpenClaw models.providers.litellm.baseUrl 一致）
OPENAI_BASE_URL=https://litellm-internal.123u.com
# 主模型：对应 OpenClaw litellm/gpt-5.2 → 此处写 gpt-5.2
OPENAI_MODEL=gpt-5.2
# 游戏 / 规格链路备用：逗号分隔；留空或删除该行表示**不使用备用**（仅 OPENAI_MODEL）。可写 litellm/xxx
OPENAI_MODEL_FALLBACKS=gemini-3.1-pro-preview

# 小说正文 / 漫画分镜 JSON（OpenAI 兼容网关 model id）
NOVEL_LLM_PRIMARY=deepseek-v4-pro
NOVEL_LLM_FALLBACK=doubao-seed-2-pro
# 小说正文：流式 / 非流式共用；超时默认 10 分钟，输出上限默认 64k tokens（见 openAiChatOutputTokenLimits 封顶）
NOVEL_LLM_TIMEOUT_MS=600000
NOVEL_LLM_MAX_OUTPUT_TOKENS=65536
NOVEL_MIN_ACCEPT_CHARS=900
# 全体兼容网关 llmJson/llmText 的 Promise.race 上限（毫秒），应 ≥ 任一较长业务超时（如小说）
LLM_WITH_TIMEOUT_MAX_MS=600000

# 封面等文生图（须与代码默认一致时可保持下列取值）
IMAGE_GEN_OPENAI_MODEL=gpt-image-2
# 单张封面经网关 gpt-image-2 约 3～6 分钟；NOVEL_LLM_TIMEOUT_MS / ensureNovelCover 默认 600000
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
# 可选：1024x1024（默认 1K）| 1024x1536 | 1536x1024
IMAGE_GEN_SIZE=1024x1024
# 漫画分镜配图并发（批量关闭时）：默认 4；网关限流时可改为 1 或 2
COMIC_PANEL_GEN_CONCURRENCY=4
# 单次 images.generate 的 n（一次请求多张，默认 4）；0 关闭批量、改回逐张/并发
IMAGE_GEN_BATCH_PANELS=4
# Azure / GPT-5 等路由改用 max_completion_tokens（默认识别 gpt-5*、o*）；网关若误判可加：OPENAI_CHAT_USE_MAX_COMPLETION_TOKENS=true
# OPENAI_JSON_MAX_OUTPUT_TOKENS=12288
# OPENAI_VISION_MAX_OUTPUT_TOKENS=512

# OpenClaw 里 litellm.headers 可整块挪成 JSON（值须为字符串或数字）
# OPENAI_EXTRA_HEADERS_JSON={"x-openclaw-timeout-ms":"25000"}

# 部分网关校验 UA，不需要可留空
OPENAI_USER_AGENT=

# ---------- 参考图 / 素材存储（默认仅会话：服务端不保留像素；解析返回的 refId 由前端写入 sessionStorage） ----------
# session | cloud
REFERENCE_ASSET_STORAGE=session
# 云模式：上传端点（实现见 src/lib/assets/reference-image-storage.cloud.ts）
# REFERENCE_ASSET_CLOUD_UPLOAD_URL=
# 可选鉴权头（Bearer 等，具体以上传服务约定为准）
# REFERENCE_ASSET_CLOUD_AUTH_HEADER=

# Docker：可与 compose 中 volume 对齐，例如 file:/app/data/app.sqlite

# ---------- 编排（Orchestration）----------
# fast | standard | rich（rich 且在创作请求中带编排 tracing 时会探测 Comfy 可达性，占位打点）
ORCHESTRATION_QUALITY_TIER=standard
# 规格 lint 后轮式 repair（无模型时每轮静默失败）；建议 2，上限不建议超过 4
ORCHESTRATION_MAX_REPAIR_ROUNDS=2
# ComfyUI 服务根 URL（不配则跳过）；示例 http://127.0.0.1:8188
COMFY_UI_BASE_URL=
# 探测超时（毫秒），GET /system_stats
COMFY_PROBE_TIMEOUT_MS=2800

# ---------- 生成 API（/api/generate*） ----------
# POST 正文最大字节数（先于 JSON.parse，防超大正文）
# 漫画创作会粘贴较长梗概；过小易 413（默认约 512KB）
GENERATE_BODY_MAX_BYTES=524288
# 单机滑动窗口毫秒（多实例无效，需网关/Redis）
GENERATE_RL_WINDOW_MS=60000
GENERATE_RL_POST_MAX=24
GENERATE_RL_STREAM_MAX=20
GENERATE_RL_VARIANTS_MAX=10
# 设为 1 时向 stdout 打单行 JSON（含 requestId / 耗时等）
GENERATE_STRUCTURED_LOG=

# ---------- 开发：与手机统一「同一站点」（主题 / 参考图会话 / 作品 Cookie 按 origin 隔离）----------
# 局域网本机 IP + 端口（与 npm run dev 一致，一般为 8888），不要末尾斜杠：
# NEXT_PUBLIC_DEV_CANONICAL_ORIGIN=http://192.168.153.1:8888
# 可选：设为 1 时，凡访问非上述 origin（如 localhost）的请求会被 307 重定向到统一地址（需在 .env.local 配好上一行）
# DEV_FORCE_CANONICAL_ORIGIN=

