DATABASE_URL="file:./dev.db"

# ---------- 密钥与网关（部署时配置；业务参数见 src/lib/product-config.ts） ----------
OPENAI_API_KEY=
# LiteLLM 根地址；若末尾无 /v1 会自动补上
OPENAI_BASE_URL=https://litellm-internal.123u.com
# 部分网关校验 UA，不需要可留空
OPENAI_USER_AGENT=

# 封面 Gemini 降级（可选）
# GEMINI_API_KEY=
# GEMINI_BASE_URL=

# 非 OpenAI 兼容 Provider（可选，模型 id 见 product-config.ts）
# LLM_PROVIDER=openai
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# Docker：可与 compose 中 volume 对齐，例如 file:/app/data/app.sqlite

# ---------- 参考图云存储（仅当 product-config 中 referenceAssets.storageMode=cloud） ----------
# REFERENCE_ASSET_CLOUD_UPLOAD_URL=
# REFERENCE_ASSET_CLOUD_AUTH_HEADER=

# ---------- ComfyUI（可选侧车；未配置则走 OpenAI 兼容文生图） ----------
# COMFY_UI_BASE_URL=http://127.0.0.1:8188

# ---------- 用户登录与 OAuth（商业化后端 Phase 1） ----------
# 本地开发模拟登录（/login → 开发登录）
# OAUTH_DEV_ENABLED=1
# 开发登录自动赋予 admin 角色（可访问 /admin）
# OAUTH_DEV_ADMIN=1
#
# 微信开放平台 · 网站应用
# OAUTH_WECHAT_APP_ID=
# OAUTH_WECHAT_APP_SECRET=
# QQ / 飞书 / LINE / 抖音（handler 待补全，先配密钥占位）
# OAUTH_QQ_APP_ID=
# OAUTH_QQ_APP_SECRET=
# OAUTH_FEISHU_APP_ID=
# OAUTH_FEISHU_APP_SECRET=
# OAUTH_LINE_CHANNEL_ID=
# OAUTH_LINE_CHANNEL_SECRET=
# OAUTH_DOUYIN_CLIENT_KEY=
# OAUTH_DOUYIN_CLIENT_SECRET=
#
# 新作品默认可见性：public | pending_review | hidden
# DEFAULT_WORK_VISIBILITY=pending_review

# ---------- 微信 JS-SDK 分享（公众号 / 开放平台，可与 OAUTH_WECHAT_* 共用） ----------
# WECHAT_MP_APP_ID=
# WECHAT_MP_APP_SECRET=

# ---------- 商业化 · 额度 / 支付（Phase 3） ----------
# 开发模拟支付与 Webhook（/billing 一键订阅测试）
# PAYMENT_DEV_MODE=1
# PAYMENT_WEBHOOK_SECRET=请改成你自己的密钥
# 微信支付商户 API v2 密钥（生产验签占位，待接证书）
# WECHAT_PAY_API_KEY=

# ---------- 基础设施（Phase 4） ----------
# SQLite（默认）或 Postgres：
# DATABASE_URL=postgresql://oneone:pass@localhost:5432/oneone
# REDIS_URL=redis://localhost:6379
# JOB_WORKER_SECRET=
# CRON_SECRET=
# STORAGE_MODE=local
# STORAGE_MODE=s3
# STORAGE_S3_ENDPOINT=http://localhost:9000
# STORAGE_S3_BUCKET=oneone-assets
# STORAGE_S3_ACCESS_KEY=
# STORAGE_S3_SECRET_KEY=
# STORAGE_S3_PUBLIC_URL=http://localhost:9000/oneone-assets
# STORAGE_S3_REGION=us-east-1
# BLOB_PUBLIC_BASE_URL=

# ---------- 超级管理员（本地删测试小说/漫画） ----------
#
# 【开发期临时】免填密钥，广场卡片右上角即可「管理删除」任意作品（仅 npm run dev，production 不生效）：
# DEV_SUPER_ADMIN=1
# NEXT_PUBLIC_DEV_SUPER_ADMIN=1
#
# 【生产 / 手动模式】设 SUPER_ADMIN_SECRET，在广场底部「超级管理员」面板填入同一字符串：
# SUPER_ADMIN_SECRET=请改成你自己的强密码
#
# 【可选】白名单：浏览器 owner cookie 写入后免填密钥（见 src/lib/constants.ts 的 OWNER_COOKIE）
# SUPER_ADMIN_OWNER_KEYS=

# ---------- 火山引擎 · 豆包语音 TTS（小说听书） ----------
# 控制台 → 豆包语音 → 应用 →「服务接口认证信息」中的 APP ID、Access Token
# 文档 https://www.volcengine.com/docs/6561/1257584 · 音色 https://www.volcengine.com/docs/6561/97465
# VOLC_TTS_APP_ID=   （或 VOLC_TTS_APPID）
# VOLC_TTS_ACCESS_TOKEN=   （或 VOLC_TTS_TOKEN，可带前缀 Bearer ）
# VOLC_TTS_VOICE_TYPE=BV701_streaming   # 仅作默认音色；听书页可在 UI 切换（擎苍/温柔淑女/古风少御等）
# VOLC_TTS_CLUSTER=volcano_tts

# ---------- 开发 / 运维开关（非产品参数） ----------
# Playwright E2E：设为 1 时 /api/projects/[id]/refine 走确定性 stub（勿用于生产）
# E2E_REFINE_STUB=
# 设为 1 时向 stdout 打单行 JSON（含 requestId / 耗时等）
# GENERATE_STRUCTURED_LOG=
# Playwright E2E：Agentic 模块仅用 template fallback，避免 LLM 超时
# E2E_AGENTIC_FALLBACK_ONLY=1
# 文生图单次请求超时（毫秒）；漫画分镜配图可单独覆盖，默认 12 分钟，最大 30 分钟
# IMAGE_GEN_TIMEOUT_MS=720000
# COMIC_PANEL_IMAGE_TIMEOUT_MS=720000
# 设为 1 且 NODE_ENV≠production 时，variants 响应附带 directorSummary（调试用）
# VARIANTS_DIRECTOR_SUMMARY=

# 可选：联网检索增强（游戏规格）
# TAVILY_API_KEY=

# ---------- 游戏编排 · Astrocade 级（默认见 product-config.ts） ----------
# 编排档位：fast | standard | rich | astrocade（默认 astrocade = MultiAgent + 深度 Brief）
# ORCHESTRATION_QUALITY_TIER=astrocade
# Agentic 玩法模块（LLM 生成 JS 沙箱）；设为 0 关闭，回退专用 Phaser/Godot 模板
# AGENTIC_GAME_MODULE=0

# ---------- 开发：与手机统一「同一站点」 ----------
# NEXT_PUBLIC_DEV_CANONICAL_ORIGIN=http://192.168.153.1:8888
# DEV_FORCE_CANONICAL_ORIGIN=1
