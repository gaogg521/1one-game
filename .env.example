DATABASE_URL="file:./dev.db"

# ---------- 密钥与网关（部署时配置；业务参数见 src/lib/product-config.ts） ----------
OPENAI_API_KEY=
# LiteLLM 根地址；若末尾无 /v1 会自动补上
OPENAI_BASE_URL=https://litellm-internal.123u.com
# 部分网关校验 UA，不需要可留空
OPENAI_USER_AGENT=

# 封面 Gemini 降级（可选）
# GEMINI_API_KEY=
# GEMINI_BASE_URL=

# 非 OpenAI 兼容 Provider（可选，模型 id 见 product-config.ts）
# LLM_PROVIDER=openai
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# Docker：可与 compose 中 volume 对齐，例如 file:/app/data/app.sqlite

# ---------- 参考图云存储（仅当 product-config 中 referenceAssets.storageMode=cloud） ----------
# REFERENCE_ASSET_CLOUD_UPLOAD_URL=
# REFERENCE_ASSET_CLOUD_AUTH_HEADER=

# ---------- ComfyUI（可选侧车；未配置则走 OpenAI 兼容文生图） ----------
# COMFY_UI_BASE_URL=http://127.0.0.1:8188

# ---------- 超级管理员（本地删测试小说/漫画） ----------
#
# 【开发期临时】免填密钥，广场卡片右上角即可「管理删除」任意作品（仅 npm run dev，production 不生效）：
# DEV_SUPER_ADMIN=1
# NEXT_PUBLIC_DEV_SUPER_ADMIN=1
#
# 【生产 / 手动模式】设 SUPER_ADMIN_SECRET，在广场底部「超级管理员」面板填入同一字符串：
# SUPER_ADMIN_SECRET=请改成你自己的强密码
#
# 【可选】白名单：浏览器 owner cookie 写入后免填密钥（见 src/lib/constants.ts 的 OWNER_COOKIE）
# SUPER_ADMIN_OWNER_KEYS=

# ---------- 火山引擎 · 豆包语音 TTS（小说听书） ----------
# 控制台 → 豆包语音 → 应用 →「服务接口认证信息」中的 APP ID、Access Token
# 文档 https://www.volcengine.com/docs/6561/1257584 · 音色 https://www.volcengine.com/docs/6561/97465
# VOLC_TTS_APP_ID=   （或 VOLC_TTS_APPID）
# VOLC_TTS_ACCESS_TOKEN=   （或 VOLC_TTS_TOKEN，可带前缀 Bearer ）
# VOLC_TTS_VOICE_TYPE=BV701_streaming   # 仅作默认音色；听书页可在 UI 切换（擎苍/温柔淑女/古风少御等）
# VOLC_TTS_CLUSTER=volcano_tts

# ---------- 开发 / 运维开关（非产品参数） ----------
# Playwright E2E：设为 1 时 /api/projects/[id]/refine 走确定性 stub（勿用于生产）
# E2E_REFINE_STUB=
# 设为 1 时向 stdout 打单行 JSON（含 requestId / 耗时等）
# GENERATE_STRUCTURED_LOG=
# 设为 1 且 NODE_ENV≠production 时，variants 响应附带 directorSummary（调试用）
# VARIANTS_DIRECTOR_SUMMARY=

# 可选：联网检索增强（游戏规格）
# TAVILY_API_KEY=

# ---------- 开发：与手机统一「同一站点」 ----------
# NEXT_PUBLIC_DEV_CANONICAL_ORIGIN=http://192.168.153.1:8888
# DEV_FORCE_CANONICAL_ORIGIN=1
