generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// 注册用户（OAuth / 邮箱 / 用户名）；legacyOwnerKey 桥接匿名 Cookie 作品。
model User {
  id              String   @id @default(cuid())
  legacyOwnerKey  String?  @unique
  /// 登录用户名（小写存储，唯一）
  username        String?  @unique
  email           String?  @unique
  phone           String?  @unique
  displayName     String?
  avatarUrl       String?
  /// scrypt 哈希（用户名/邮箱注册）；OAuth 用户可为空
  passwordHash    String?
  /// user | admin | super_admin
  role            String   @default("user")
  /// 裂变邀请码（分享链接 ?ref=）
  referralCode    String   @unique @default(cuid())
  referredById    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  /// 可用生成额度（积分）；订阅月度额度另计
  quotaBalance  Int      @default(0)
  referredBy   User?          @relation("UserReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals    User[]         @relation("UserReferrals")
  oauthAccounts OAuthAccount[]
  sessions     UserSession[]
  quotaLedger  QuotaLedger[]
  referralRewardsGiven ReferralReward[] @relation("ReferrerRewards")
  referralRewardReceived ReferralReward? @relation("InviteeReward")
  subscriptions UserSubscription[]
  paymentEvents PaymentEvent[]

  @@index([role])
}

/// 邮箱验证码（注册 / 找回密码）
model EmailVerification {
  id         String    @id @default(cuid())
  email      String
  codeHash   String
  purpose    String    @default("register")
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email, purpose])
  @@index([expiresAt])
}

/// 额度流水（邀请奖励、购买、生成消耗）
model QuotaLedger {
  id           String   @id @default(cuid())
  userId       String
  delta        Int
  balanceAfter Int
  /// referral_signup | referral_invitee | purchase | generation_* | signup_bonus | admin_grant
  reason       String
  refType      String?
  refId        String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([reason])
  @@index([createdAt])
}

/// 邀请裂变奖励（一次性的邀请关系记录）
model ReferralReward {
  id          String   @id @default(cuid())
  referrerId  String
  inviteeId   String   @unique
  credits     Int
  createdAt   DateTime @default(now())

  referrer User @relation("ReferrerRewards", fields: [referrerId], references: [id], onDelete: Cascade)
  invitee  User @relation("InviteeReward", fields: [inviteeId], references: [id], onDelete: Cascade)

  @@index([referrerId])
}

/// 套餐定义（free / creator / pro）
model SubscriptionPlan {
  id            String   @id
  name          String
  monthlyQuota  Int
  priceCents    Int
  currency      String   @default("CNY")
  active        Boolean  @default(true)
  featuresJson  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscriptions UserSubscription[]
}

/// 用户订阅周期
model UserSubscription {
  id             String   @id @default(cuid())
  userId         String
  planId         String
  /// active | cancelled | expired | pending
  status         String   @default("pending")
  periodStart    DateTime
  periodEnd      DateTime
  externalSubId  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan SubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([periodEnd])
}

/// 支付订单 / Webhook 事件
model PaymentEvent {
  id          String    @id @default(cuid())
  userId      String?
  /// wechat | alipay | dev
  provider    String
  orderId     String    @unique
  amountCents Int
  currency    String    @default("CNY")
  /// pending | paid | failed | refunded
  status      String    @default("pending")
  planId      String?
  payloadJson String?
  createdAt   DateTime  @default(now())
  paidAt      DateTime?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([provider])
}

/// 异步任务（长生成迁移队列；单实例可用内存，多实例配 REDIS_URL）
model JobQueueItem {
  id          String    @id @default(cuid())
  /// novel_generate | comic_generate | cover_gen | ...
  type        String
  payloadJson String
  /// pending | running | done | failed
  status      String    @default("pending")
  attempts    Int       @default(0)
  lastError   String?
  runAfter    DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, runAfter])
  @@index([type])
}

/// 第三方登录绑定（微信 / QQ / 飞书 / Line / 抖音等）
model OAuthAccount {
  id              String    @id @default(cuid())
  userId          String
  /// wechat | qq | feishu | line | douyin | dev
  provider        String
  providerUserId  String
  accessToken     String?
  refreshToken    String?
  expiresAt       DateTime?
  profileJson     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
}

/// 登录会话（HttpOnly gcreator_session）
model UserSession {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

/// 分享 / 裂变归因事件
model ShareEvent {
  id              String   @id @default(cuid())
  shareCode       String
  workType        String
  workId          String
  /// wechat | qq | feishu | line | douyin | copy | link | unknown
  channel         String   @default("unknown")
  referrerUserId  String?
  visitorOwnerKey String?
  createdAt       DateTime @default(now())

  @@index([shareCode])
  @@index([workId, workType])
  @@index([referrerUserId])
}

/// 平台运行时配置（密钥加密存储；模型等可覆盖 product-config 默认值）
model PlatformRuntimeConfig {
  id              String   @id @default("default")
  /// AES-GCM 加密 JSON（API Key 等敏感字段）
  secretsEnc      String?
  updatedByUserId String?
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
}

/// 平台邮件配置（SMTP / Resend；密钥加密存储；后台可改，无需改 .env）
model PlatformEmailConfig {
  id              String   @id @default("default")
  configEnc       String?
  updatedByUserId String?
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
}

/// 后台治理审计
model AdminAuditLog {
  id            String   @id @default(cuid())
  actorUserId   String?
  actorOwnerKey String?
  action        String
  targetType    String?
  targetId      String?
  detailJson    String?
  createdAt     DateTime @default(now())

  @@index([action])
  @@index([createdAt])
}

/// 访客或未来登录用户的作品容器；ownerKey 由 HttpOnly Cookie 持有，便于后续接入 OAuth 时迁移合并。
model Project {
  id        String   @id @default(cuid())
  ownerKey  String
  /// public | hidden | pending_review
  visibility String  @default("public")
  featured   Boolean @default(false)
  /// 可选短链 slug，用于 /s/[shareCode] 跳转试玩页
  shareCode String?  @unique
  title     String
  prompt    String
  specJson  String
  status    String   @default("ready")
  /// 试玩首帧截图 URL 路径，如 /covers/{id}.jpg；由客户端截图后 PATCH 写入
  coverPath String?
  /// 累计试玩次数（任何访客打开试玩页面时递增，不需要登录）
  playCount Int      @default(0)
  /// 累计点赞数（访客通过 localStorage 去重，防止重复点）
  likeCount Int      @default(0)
  /// 试玩页多回合 refine 日志 JSON（仅主人可读写入）
  refinementLogJson String?
  /// Creative Brief 结构化扩写 JSON（与 specJson 并列持久化）
  creativeBriefJson String?
  /// LLM 生成的旋律音符序列 JSON（无第三方 BGM API Key 时的降级方案，生成后缓存）
  bgmNotesJson      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerKey])
  @@index([visibility, featured, playCount])
  @@index([visibility, createdAt])
}

model Novel {
  id        String   @id @default(cuid())
  ownerKey  String
  visibility String  @default("public")
  featured   Boolean @default(false)
  shareCode String?  @unique
  title     String
  prompt    String
  content   String
  summary   String?
  /// short | medium | long
  lengthTier String? @default("medium")
  /// 长篇流水线元数据 JSON：设定圣经、章规划等（NovelGenerationMeta）
  generationMetaJson String?
  /// Creative Brief 结构化扩写 JSON
  creativeBriefJson String?
  /// 角色资产库 JSON（ComicCharacterRoster）
  characterRosterJson String?
  status    String   @default("ready")
  coverPath String?
  playCount Int      @default(0)
  likeCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comics Comic[]

  @@index([ownerKey])
  @@index([visibility, featured, playCount])
  @@index([visibility, createdAt])
}

model Comic {
  id        String   @id @default(cuid())
  ownerKey  String
  visibility String  @default("public")
  featured   Boolean @default(false)
  novelId   String?
  shareCode String?  @unique
  title     String
  prompt    String
  imageUrls String
  /// 漫画改编 Brief JSON（可与关联 Novel 的 Brief 并存）
  creativeBriefJson String?
  status    String   @default("ready")
  coverPath String?
  likeCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  novel Novel? @relation(fields: [novelId], references: [id], onDelete: SetNull)

  @@index([ownerKey])
  @@index([novelId])
  @@index([visibility, featured, likeCount])
  @@index([visibility, createdAt])
}

/// 用户评论（game / novel / comic 三类内容通用；匿名 ownerKey 识别作者）
model Comment {
  id        String   @id @default(cuid())
  /// "game" | "novel" | "comic"
  workType  String
  workId    String
  /// 匿名作者标识（来自 gcreator_owner cookie）
  ownerKey  String
  /// 显示昵称（未登录时默认"访客"）
  nickname  String   @default("访客")
  content   String
  createdAt DateTime @default(now())

  @@index([workType, workId, createdAt])
  @@index([ownerKey])
}

/// 生成失败日志：game / novel / comic 三类内容的生成错误记录
model GenerationError {
  id          String   @id @default(cuid())
  /// 内容类型：game | novel | comic
  contentType String
  /// 触发生成的 prompt 前 512 字符（便于统计高频失败主题）
  promptSnippet String
  /// 错误类型标签：timeout | rate_limit | context_length | parse_error | upstream | unknown
  errorType   String   @default("unknown")
  /// 原始错误消息（截断至 512 字符）
  errorMessage String?
  ownerKey    String?
  createdAt   DateTime @default(now())

  @@index([contentType, createdAt])
  @@index([errorType, createdAt])
  @@index([createdAt])
}
