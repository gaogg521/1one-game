# Copy to scripts/deploy.local.env (gitignored) and fill in real values.
# Or export the same keys in your shell before running deploy scripts.

OPERONE_DEPLOY_HOST=your.server.ip.or.hostname
OPERONE_DEPLOY_USER=root
OPERONE_DEPLOY_PASSWORD=your-ssh-password
# Optional: use key instead of password (set path to private key file)
# OPERONE_DEPLOY_KEY_PATH=C:/Users/you/.ssh/id_rsa

OPERONE_DEPLOY_REPO=/opt/operone
OPERONE_DEPLOY_APP_PORT=80
# Optional: only used in success log messages
# OPERONE_DEPLOY_DOMAIN=app.example.com
