# Godot 4.4.1 导出/headless — 供 CentOS 7 宿主机通过 docker 调用
FROM debian:bookworm-slim

RUN apt-get update \
  && apt-get install -y curl ca-certificates unzip \
    libfontconfig1 libdbus-1-3 libx11-6 libxext6 libxrender1 libxi6 libgl1-mesa-glx libasound2 \
  && rm -rf /var/lib/apt/lists/*

ENV GODOT_VERSION=4.4.1
ENV GODOT_BIN=/opt/godot/Godot_v${GODOT_VERSION}-stable_linux.x86_64

RUN mkdir -p /opt/godot \
  && curl -fsSL "https://github.com/godotengine/godot/releases/download/${GODOT_VERSION}-stable/Godot_v${GODOT_VERSION}-stable_linux.x86_64.zip" \
    -o /tmp/godot.zip \
  && unzip -q /tmp/godot.zip -d /opt/godot \
  && chmod +x "$GODOT_BIN" \
  && rm -f /tmp/godot.zip

WORKDIR /app
ENTRYPOINT ["/opt/godot/Godot_v4.4.1-stable_linux.x86_64"]
